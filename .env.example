# Neon Postgres connection string.
# Get this from your Neon project dashboard -> Connection Details -> "Pooled connection".
# It should look like:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
#
# For local dev, copy this file to .env.local and paste your string below.
DATABASE_URL=
